{
	"name": "@codelia/core",
	"version": "0.1.75",
	"license": "MIT",
	"type": "module",
	"files": [
		"dist",
		"prompts"
	],
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"scripts": {
		"build": "tsup src/index.ts --format esm --dts --clean && tsup src/index.ts --format cjs --define.import.meta.url=__filename",
		"typecheck": "tsc --noEmit"
	},
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.110.0",
		"@codelia/config": "0.1.75",
		"@codelia/shared-types": "0.1.75",
		"json-schema": "^0.4.0",
		"openai": "^6.46.0",
		"ws": "^8.21.0",
		"zod": "^4.3.5"
	}
}
